{
  "name": "dev-launch-pad",
  "version": "1.8.0",
  "description": "A safe Windows desktop command center for local coding projects.",
  "main": "out/main/index.js",
  "author": "suzuk",
  "homepage": "./",
  "scripts": {
    "dev": "electron-vite dev",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.electron.json",
    "build": "npm run typecheck && electron-vite build",
    "package": "npm run package:win",
    "package:win": "npm run build && electron-builder --win portable --publish never && npm run package:latest",
    "package:latest": "node scripts/copy-latest-portable.mjs",
    "preview": "electron-vite preview"
  },
  "build": {
    "appId": "com.suzuk.devlaunchpad",
    "productName": "Dev Launch Pad",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/dev-launch-pad.ico",
        "to": "dev-launch-pad.ico"
      }
    ],
    "win": {
      "icon": "resources/dev-launch-pad.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
